KITE_LOGIN_TIMEOUT_SECONDS=180
KITE_LOGIN_POLL_INTERVAL_SECONDS=3
KITE_API_KEY=
KITE_API_SECRET=
APP_MODE=http
APP_PORT=8080
APP_HOST=localhost
